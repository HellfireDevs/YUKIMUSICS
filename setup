#!/bin/bash

# Terminal Colors
CYAN='\033[1;96m'
GREEN='\033[1;92m'
YELLOW='\033[1;93m'
RESET='\033[0m'

echo -e "\n${CYAN}=== ʏᴜᴋɪ ᴀᴜᴛᴏ ɪɴsᴛᴀʟʟᴇʀ ===${RESET}\n"

# 1. Update & Install Python 3.11
echo -e "${CYAN}[*] Updating system & installing Python 3.11...${RESET}"
sudo apt-get update -y > /dev/null 2>&1
sudo apt-get install python3.11 python3.11-venv python3-pip -y > /dev/null 2>&1
echo -e "${GREEN}✓ Python 3.11 Installed!${RESET}"

# 2. Install Node.js & PM2
echo -e "${CYAN}[*] Installing PM2 & Node.js...${RESET}"
sudo apt-get install nodejs npm -y > /dev/null 2>&1
sudo npm install -g pm2 -y > /dev/null 2>&1
echo -e "${GREEN}✓ PM2 Installed!${RESET}"

# 3. Create Virtual Environment
echo -e "${CYAN}[*] Creating Virtual Environment...${RESET}"
python3.11 -m venv venv
echo -e "${GREEN}✓ Venv Created!${RESET}"

# 4. Install Requirements
echo -e "${CYAN}[*] Installing requirements...${RESET}"
source venv/bin/activate
pip install -r requirements.txt > /dev/null 2>&1
echo -e "${GREEN}✓ Requirements Installed!${RESET}"

# 5. Create .env file if missing
if [ ! -f .env ]; then
    cp sample.env .env
    echo -e "${GREEN}✓ Created .env template!${RESET}"
fi

# 6. PM2 Registration (Start & Stop)
echo -e "${CYAN}[*] Registering Bot in PM2...${RESET}"
pm2 start start --interpreter bash --name "yuki" > /dev/null 2>&1
pm2 stop yuki > /dev/null 2>&1
pm2 save > /dev/null 2>&1
echo -e "${GREEN}✓ Bot Registered and Stopped!${RESET}"

# 7. Inject Dashboard Shortcuts
echo -e "${CYAN}[*] Creating Terminal Dashboard...${RESET}"
sed -i '/# YUKI Dashboard/d' ~/.bashrc
sed -i '/alias logs=/d' ~/.bashrc
sed -i '/alias restart=/d' ~/.bashrc
sed -i '/alias stop=/d' ~/.bashrc
sed -i '/alias setup=/d' ~/.bashrc
sed -i '/alias version=/d' ~/.bashrc
sed -i '/alias update=/d' ~/.bashrc

echo "# YUKI Dashboard Aliases" >> ~/.bashrc
echo "alias logs='pm2 logs yuki'" >> ~/.bashrc
echo "alias restart='pm2 restart yuki'" >> ~/.bashrc
echo "alias stop='pm2 stop yuki'" >> ~/.bashrc
echo "alias setup='bash ~/YUKIXMUSIC/setup'" >> ~/.bashrc
echo "alias version='python3 ~/YUKIXMUSIC/yuki.py version'" >> ~/.bashrc
echo "alias update='python3 ~/YUKIXMUSIC/yuki.py update'" >> ~/.bashrc

echo -e "\n${GREEN}=== sᴇᴛᴜᴘ sᴜᴄᴄᴇssғᴜʟʟ ===${RESET}"
echo -e "--------------------------------------------------"
echo -e "${YELLOW}Step 1:${RESET} Edit your config : ${CYAN}nano .env${RESET}"
echo -e "${YELLOW}Step 2:${RESET} Refresh terminal : ${CYAN}source ~/.bashrc${RESET}"
echo -e "${YELLOW}Step 3:${RESET} Start the bot    : ${CYAN}restart${RESET}"
echo -e "${YELLOW}Step 4:${RESET} Check bot logs   : ${CYAN}logs${RESET}"
echo -e "--------------------------------------------------"
